# apps/alpha (Primer 제출 알파 · Next.js) 환경변수 예시
# 실제 값은 각자 환경에 맞게 채운다. .env.local 은 커밋하지 않는다(.gitignore).

# Supabase (momso 중앙 계정 — 공개 가능한 publishable/anon 키만 클라이언트 사용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Google 로그인 (알파=구글 단독 로그인)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# 서버 전용 — 사용자 BYO 키(LLM/스토리지) 복호화용. 절대 공개 금지.
MOMSO_ENCRYPTION_KEY=
